{
  "name": "backend",
  "version": "1.0.0",
  "description": "Blockchain crowdfunding platform backend with smart contracts",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:local": "hardhat ignition deploy ./ignition/modules/CrowdfundingPlatform.js --network localhost",
    "deploy:sepolia": "hardhat ignition deploy ./ignition/modules/CrowdfundingPlatform.js --network sepolia",
    "deploy:mumbai": "hardhat ignition deploy ./ignition/modules/CrowdfundingPlatform.js --network mumbai",
    "node": "hardhat node",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "verify:sepolia": "hardhat verify --network sepolia",
    "console": "hardhat console"
  },
  "keywords": [
    "blockchain",
    "crowdfunding",
    "ethereum",
    "solidity",
    "hardhat",
    "smart-contracts"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "hardhat": "^2.26.2",
    "hardhat-dependency-compiler": "^1.2.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^16.6.1"
  }
}
